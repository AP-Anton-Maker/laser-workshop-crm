# Шаблон переменных окружения для anton-maker.ru CRM
# Скопируйте этот файл в .env и заполните актуальными значениями

# Django настройки
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=anton-maker.ru,www.anton-maker.ru,localhost

# База данных (SQLite по умолчанию)
DATABASE_URL=sqlite:///data/db.sqlite3

# VK API настройки
VK_API_VERSION=5.131
VK_APP_ID=your_vk_app_id
VK_SERVICE_TOKEN=your_vk_service_token
VK_CONFIRMATION_CODE=your_vk_confirmation_code
ADMIN_VK_ID=your_admin_vk_id

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Настройки безопасности
DJANGO_SUPERUSER_EMAIL=admin@anton-maker.ru
DJANGO_SUPERUSER_PASSWORD=change-me-in-production
DJANGO_SUPERUSER_USERNAME=admin

# Флаги запуска
RUN_MIGRATIONS=1

# Caddy настройки
CADDY_DOMAIN=anton-maker.ru
